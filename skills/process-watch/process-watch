#!/usr/bin/env bash
set -euo pipefail
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV="$BASE_DIR/.venv"
PY="$VENV/bin/python"

if [[ ! -x "$PY" ]]; then
  echo "process-watch: missing venv at $VENV" >&2
  echo "Run: cd $BASE_DIR && python3 -m venv .venv && . .venv/bin/activate && pip install psutil" >&2
  exit 1
fi

exec "$PY" "$BASE_DIR/scripts/process-watch.py" "$@"
