#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PY="$ROOT_DIR/.venv/bin/python"

if [[ ! -x "$VENV_PY" ]]; then
  echo "Error: virtualenv not found at $ROOT_DIR/.venv"
  echo "Create it with: python3 -m venv $ROOT_DIR/.venv && $ROOT_DIR/.venv/bin/pip install fastembed"
  exit 1
fi

exec "$VENV_PY" "$ROOT_DIR/embed.py" "$@"
